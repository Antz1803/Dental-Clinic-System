# Stage 1: Build the application
FROM mcr.microsoft.com/dotnet/sdk:9.0 AS build
WORKDIR /src

# Copy csproj directly from the root and restore dependencies
COPY ["DCAS.csproj", "./"]
RUN dotnet restore "DCAS.csproj"

# Copy the remaining source code and build
COPY . .
RUN dotnet build "DCAS.csproj" -c Release -o /app/build

# Stage 2: Publish the application
FROM build AS publish
RUN dotnet publish "DCAS.csproj" -c Release -o /app/publish /p:UseAppHost=false

# Stage 3: Final runtime environment
FROM mcr.microsoft.com/dotnet/aspnet:9.0 AS final
WORKDIR /app
COPY --from=publish /app/publish .

# Render defaults to port 10000, so we tell ASP.NET to listen there
ENV ASPNETCORE_URLS=http://+:10000

ENTRYPOINT ["dotnet", "DCAS.dll"]
